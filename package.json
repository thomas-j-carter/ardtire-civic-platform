{
  "name": "ardtire-civic-platform",
  "private": true,
  "version": "0.0.0",
  "packageManager": "pnpm@10.6.1",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "dev": "bash infra/scripts/dev-all.sh",
    "build": "turbo build",
    "typecheck": "turbo typecheck",
    "lint": "turbo lint",
    "format": "biome format . --write",
    "format:check": "biome format .",
    "lint:biome": "biome lint .",
    "lint:biome:fix": "biome lint . --write",
    "check": "pnpm -s format:check && pnpm -s lint && pnpm -s typecheck && pnpm -s test",
    "test": "turbo test",
    "storybook": "pnpm -C apps/storybook storybook",
    "storybook:build": "pnpm -C apps/storybook build",
    "infra:up": "bash infra/scripts/dev-up.sh",
    "infra:down": "bash infra/scripts/dev-down.sh",
    "dev:infra": "pnpm infra:up",
    "dev:api": "pnpm -C services/api dev",
    "dev:public": "pnpm -C apps/public dev",
    "dev:portal": "pnpm -C apps/portal dev",
    "dev:admin": "pnpm -C apps/admin dev",
    "db:migrate": "pnpm -C packages/db db:migrate",
    "db:seed": "node infra/scripts/seed-register.mjs"
  },
  "devDependencies": {
    "biome": "^0.3.3",
    "turbo": "^2.8.14",
    "typescript": "^5.9.3"
  }
}

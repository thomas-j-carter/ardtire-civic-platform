{
  "name": "@ardtire/api-contract",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "contract:validate": "redocly lint --config ../../.redocly.yaml ../../openapi/ardtire-platform.openapi.yaml",
    "contract:gen": "openapi-typescript ../../openapi/ardtire-platform.openapi.yaml -o ./src/gen/types.ts",
    "build": "tsc -p tsconfig.json --noEmit",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "biome lint .",
    "test": "echo \"no tests (contract package)\""
  },
  "devDependencies": {
    "@redocly/cli": "^1.34.0",
    "openapi-typescript": "^7.6.1",
    "typescript": "^5.0.0"
  }
}
